<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#04091a;--bg2:#060d24;--bg3:#08122e;--surface:#0b1735;--surface2:#0e1f42;
  --border:rgba(100,149,237,.15);--border2:rgba(100,149,237,.28);
  --gold:#f5be0b;--gold-dim:rgba(245,190,11,.12);--gold-glow:rgba(245,190,11,.3);
  --green:#22c55e;--green-dim:rgba(34,197,94,.13);
  --blue:#4a90d9;--blue-light:#7ab3e8;--blue-dim:rgba(74,144,217,.12);
  --text:#e8edf8;--muted:rgba(180,200,240,.55);
  --fd:'Syne',sans-serif;--fb:'DM Sans',sans-serif;--fm:'JetBrains Mono',monospace;
}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:var(--fb);overflow-x:hidden}
.geo-bg{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.geo-bg svg{width:100%;height:100%;opacity:.035}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:200;display:flex;align-items:center;justify-content:space-between;padding:1.25rem 4rem;background:rgba(4,9,26,.92);backdrop-filter:blur(14px);border-bottom:1px solid var(--border)}
.nav-logo{font-family:var(--fd);font-size:1.1rem;font-weight:800;color:var(--text);text-decoration:none}
.nav-logo span{color:var(--gold)}
.nav-back{font-family:var(--fm);font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:.5rem;transition:color .25s}
.nav-back:hover{color:var(--gold)}
.lang-switcher{display:flex;gap:.55rem;align-items:center}
.lang-btn{width:32px;height:32px;border-radius:50%;border:2px solid transparent;background:var(--surface);cursor:pointer;display:flex;align-items:center;justify-content:center;overflow:hidden;transition:border-color .25s,transform .2s;padding:0}
.lang-btn img{width:100%;height:100%;object-fit:cover;display:block;border-radius:50%}
.lang-btn:hover{transform:scale(1.15);border-color:var(--gold)}
.lang-btn.active{border-color:var(--gold);box-shadow:0 0 0 3px var(--gold-dim)}

main{position:relative;z-index:1;padding:7rem 4rem 5rem;max-width:1100px;margin:0 auto}

/* HERO */
.proj-hero{padding:4rem 0 3rem;border-bottom:1px solid var(--border);margin-bottom:4rem}
.proj-num{font-family:var(--fm);font-size:.65rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem}
.proj-hero-title{font-family:var(--fd);font-size:clamp(2rem,4.5vw,3.8rem);font-weight:800;letter-spacing:-.04em;line-height:.95;margin-bottom:1.5rem}
.proj-hero-title em{font-style:normal;color:var(--gold)}
.proj-meta{display:flex;gap:2.5rem;flex-wrap:wrap}
.meta-item{display:flex;flex-direction:column;gap:.3rem}
.meta-label{font-family:var(--fm);font-size:.57rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.meta-value{font-family:var(--fd);font-size:.88rem;font-weight:600}

/* SHARED */
.block-tag{font-family:var(--fm);font-size:.62rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:.9rem}
.block-title{font-family:var(--fd);font-size:1.55rem;font-weight:800;letter-spacing:-.03em;margin-bottom:1.2rem;line-height:1.05}
.block-text{font-size:.91rem;line-height:1.9;color:var(--text);opacity:.82}
.block-text p+p{margin-top:1rem}
.block-text strong{color:var(--gold);font-weight:600}
.divider{height:1px;background:linear-gradient(90deg,var(--gold) 0%,var(--blue) 40%,transparent 100%);opacity:.3;margin:3.5rem 0}

/* ITEM CARDS */
.items-list{display:flex;flex-direction:column;gap:2px;background:var(--border)}

.item-card{
  background:var(--bg);padding:2.75rem 3rem;
  position:relative;overflow:hidden;
  transition:background .3s;
}
.item-card:hover{background:var(--surface)}
.item-card:hover .item-bar{transform:scaleX(1)}
.item-bar{position:absolute;bottom:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--gold),var(--blue));transform:scaleX(0);transform-origin:left;transition:transform .45s cubic-bezier(.22,1,.36,1)}

/* Card top */
.item-top{display:flex;align-items:flex-start;justify-content:space-between;gap:1.5rem;margin-bottom:1.25rem;flex-wrap:wrap}
.item-top-left{display:flex;flex-direction:column;gap:.6rem}
.item-num{font-family:var(--fm);font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.item-badges{display:flex;gap:.5rem;flex-wrap:wrap}

/* Nature badges */
.badge-academic{font-family:var(--fm);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:.3rem .9rem;border-radius:20px;background:var(--blue-dim);color:var(--blue-light);border:1.5px solid rgba(74,144,217,.4);white-space:nowrap}
.badge-report{font-family:var(--fm);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:.3rem .9rem;border-radius:20px;background:var(--gold-dim);color:var(--gold);border:1.5px solid rgba(245,190,11,.4);white-space:nowrap}
.badge-wip{font-family:var(--fm);font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:.3rem .9rem;border-radius:20px;background:rgba(245,190,11,.1);color:var(--gold);border:1.5px dashed rgba(245,190,11,.4);white-space:nowrap}

/* Download button top-right */
.item-dl-btn{
  display:inline-flex;align-items:center;gap:.55rem;flex-shrink:0;
  background:var(--gold);color:#0a0a0a;
  padding:.7rem 1.5rem;font-family:var(--fd);font-weight:700;font-size:.82rem;
  text-decoration:none;transition:transform .2s,box-shadow .2s;
  white-space:nowrap;
}
.item-dl-btn:hover{transform:translateY(-2px);box-shadow:0 8px 28px var(--gold-glow)}
.item-dl-btn-disabled{
  display:inline-flex;align-items:center;gap:.55rem;flex-shrink:0;
  border:1.5px dashed var(--border2);color:var(--muted);
  padding:.68rem 1.5rem;font-family:var(--fm);font-size:.7rem;
  letter-spacing:.06em;text-transform:uppercase;white-space:nowrap;cursor:default;
}

/* Card body */
.item-title{font-family:var(--fd);font-size:1.35rem;font-weight:800;letter-spacing:-.03em;line-height:1.1;margin-bottom:1.25rem}
.item-body{display:grid;grid-template-columns:1fr 280px;gap:3rem;align-items:start}
.item-abstract{font-size:.88rem;line-height:1.85;color:var(--text);opacity:.78}
.item-abstract p+p{margin-top:.85rem}
.item-abstract strong{color:var(--gold);font-weight:600}

/* Sidebar */
.item-sidebar{display:flex;flex-direction:column;gap:1.25rem}
.sidebar-block{background:var(--surface2);border:1px solid var(--border);padding:1.25rem}
.sidebar-label{font-family:var(--fm);font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:.75rem}
.sidebar-value{font-size:.82rem;line-height:1.7;color:var(--text);opacity:.8}
.item-thumb{width:100%;overflow:hidden;border:1px solid var(--border2);border-radius:4px;margin-bottom:.5rem}
.item-thumb img{width:100%;display:block;object-fit:cover;transition:transform .4s}
.item-card:hover .item-thumb img{transform:scale(1.03)}

/* Keywords */
.kw-list{display:flex;flex-wrap:wrap;gap:.4rem;margin-top:.75rem}
.kw-tag{font-family:var(--fm);font-size:.58rem;letter-spacing:.06em;text-transform:uppercase;padding:.22rem .65rem;border:1px solid var(--border2);color:var(--muted)}
.item-card:hover .kw-tag{border-color:rgba(245,190,11,.35);color:var(--gold)}

/* PROJ NAV */
.proj-nav{display:flex;justify-content:space-between;align-items:center;padding:2.5rem 0;border-top:1px solid var(--border);margin-top:4rem}
.pnav-link{font-family:var(--fm);font-size:.7rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);text-decoration:none;display:flex;align-items:center;gap:.5rem;transition:color .25s}
.pnav-link:hover{color:var(--gold)}
.btn-home{display:inline-flex;align-items:center;gap:.6rem;background:transparent;border:1.5px solid var(--gold);color:var(--gold);padding:.75rem 1.5rem;font-family:var(--fd);font-weight:600;font-size:.85rem;text-decoration:none;transition:background .25s,color .25s}
.btn-home:hover{background:var(--gold);color:#0a0a0a}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .75s ease,transform .75s cubic-bezier(.22,1,.36,1)}
.reveal.visible{opacity:1;transform:translateY(0)}

@media(max-width:900px){
  nav{padding:1rem 1.5rem}
  main{padding:6rem 1.5rem 3rem}
  .item-body{grid-template-columns:1fr}
  .item-sidebar{display:none}
  .item-top{flex-direction:column}
}
</style>
